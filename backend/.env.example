# Copier vers backend/.env (ne jamais committer .env)
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Médias publics (prod : https://votre-domaine.com)
PUBLIC_BASE_URL=

# Optionnel — tâches async
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

OTP_SMS_EXPIRY_SECONDS=300
